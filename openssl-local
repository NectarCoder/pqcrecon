#!/usr/bin/env bash
# Convenience wrapper for the locally built OpenSSL binary.

set -euo pipefail
IFS=$'\n\t'

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BUILD_PREFIX="${OPENSSL_BUILD_PREFIX:-$REPO_ROOT/openssl/tmp.pqcrecon}"
BIN_PATH="$BUILD_PREFIX/bin/openssl"
CONF_PATH="$BUILD_PREFIX/ssl/openssl-all.cnf"

if [[ "${1:-}" == "--build-if-missing" ]]; then
  shift
  if [[ ! -x "$BIN_PATH" ]]; then
    "$REPO_ROOT/scripts/build-openssl.sh"
  fi
fi

if [[ ! -x "$BIN_PATH" ]]; then
  echo "OpenSSL binary not found at $BIN_PATH" >&2
  echo "Run: ./scripts/build-openssl.sh" >&2
  echo "Or:  ./openssl-local --build-if-missing <openssl args>" >&2
  exit 1
fi

if [[ -z "${OPENSSL_CONF:-}" && -f "$CONF_PATH" ]]; then
  export OPENSSL_CONF="$CONF_PATH"
fi

if [[ -z "${OPENSSL_MODULES:-}" ]]; then
  if [[ -d "$BUILD_PREFIX/lib64/ossl-modules" ]]; then
    export OPENSSL_MODULES="$BUILD_PREFIX/lib64/ossl-modules"
  elif [[ -d "$BUILD_PREFIX/lib/ossl-modules" ]]; then
    export OPENSSL_MODULES="$BUILD_PREFIX/lib/ossl-modules"
  fi
fi

exec "$BIN_PATH" "$@"
